# FastAPI Text2SQL Application Environment Variables
# Copy this file to .env and replace with your actual values

# API Key for authentication
API_KEY=your_api_key_here
# API exposed port for Blue/Green deployment
API_PORT_BLUE=8010
API_PORT_GREEN=8011

# OpenAI API Key for Text2SQL conversion
# Replace with your actual OpenAI API key
# Only required if using llm_model_* = "gpt-4o"
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (Claude)
# Only required if using llm_model_* = "claude-sonnet-4-6"
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Google API Key (Gemini)
# Only required if using llm_model_* = "gemini-1.5-pro"
GOOGLE_API_KEY=your_google_api_key_here

# MySQL Database Configuration
# Replace with your actual MySQL database credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# ChromaDB server configuration
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
