# FastAPI Text2SQL Application Environment Variables
# Copy this file to .env and replace with your actual values

# API keys for authentication (comma-separated list, checked in order)
# Use API_KEYS for multiple keys. The legacy API_KEY single-value is still accepted.
API_KEYS=key_for_app,key_for_mcp,key_for_scripts
# API_KEY=your_single_key_here    # legacy fallback — used only if API_KEYS is not set
# API exposed port for Blue/Green deployment
API_PORT_BLUE=8010
API_PORT_GREEN=8011

# OpenAI API Key for Text2SQL conversion
# Replace with your actual OpenAI API key
# Only required if using llm_model_* = "gpt-4o"
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (Claude)
# Only required if using llm_model_* = "claude-sonnet-4-6"
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Google API Key (Gemini)
# Only required if using llm_model_* = "gemini-2.5-flash"
GOOGLE_API_KEY=your_google_api_key_here

# MySQL Database Configuration
# Replace with your actual MySQL database credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# ChromaDB server configuration
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# MCP (Model Context Protocol) — Claude connector at /mcp
# Bearer token that Claude sends on every request to /mcp.
# Generate with: openssl rand -hex 32
# If left empty the /mcp route is open (development only).
MCP_API_KEY=your_mcp_bearer_token_here

# Internal API key used by MCP tools when they call the FastAPI entity endpoints.
# Must be one of the keys listed in API_KEYS (or API_KEY if using the legacy variable).
# Defaults to the first entry of API_KEYS at runtime if not set explicitly.
MCP_INTERNAL_API_KEY=key_for_mcp

# Base URL the MCP tools use to reach the FastAPI server internally.
# Auto-detected from API_PORT_BLUE / API_PORT_GREEN at startup based on version parity.
# Override only if the server is behind a proxy or runs on a non-standard port.
# MCP_INTERNAL_BASE_URL=http://127.0.0.1:8010
